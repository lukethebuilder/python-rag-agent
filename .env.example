# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# Embedding model and output dimension (must stay in sync)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Chat completion settings
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CHAT_MAX_TOKENS=1024
OPENAI_CHAT_TEMPERATURE=0.2
RAG_SYSTEM_PROMPT=You answer questions using only the provided context.

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=docs

# ── Chunking & retrieval ──────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_CHUNKING_STRATEGY=recursive_character_text_splitter
RAG_DEFAULT_TOP_K=5
# Set to true to score every query with RAGAS (uses additional OpenAI tokens)
RAG_EVAL_ENABLED=false
